<!-- REQUIRED --> <!-- VALIDATION: must match EPIC-NNN pattern; must be unique -->
title: "{{ epic_title }}"
<!-- REQUIRED --> <!-- VALIDATION: max 80 chars; descriptive of the feature area -->
status: "{{ status }}"
<!-- REQUIRED --> <!-- VALIDATION: one of Backlog | Ready | In Progress | Done -->
priority: "{{ priority }}"
<!-- REQUIRED --> <!-- VALIDATION: one of Critical | High | Medium | Low -->
prd-refs:
  - "{{ fr_id_1 }}"
  - "{{ fr_id_2 }}"
<!-- REQUIRED --> <!-- VALIDATION: at least 1 FR reference; each must match FR-NNN in the PRD -->
story-count: {{ story_count }}
<!-- REQUIRED --> <!-- VALIDATION: must match actual number of stories listed below -->
estimated-points: {{ estimated_points }}
<!-- REQUIRED --> <!-- VALIDATION: must equal sum of story points -->
dependencies:
  - "{{ dependency_epic_id }}"
<!-- OPTIONAL — leave as empty array [] if no dependencies -->
