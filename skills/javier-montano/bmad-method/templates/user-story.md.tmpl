---
story-id: "{{ story_id }}"
<!-- REQUIRED --> <!-- VALIDATION: must match STORY-NNN pattern; must be unique -->
epic-ref: "{{ epic_id }}"
<!-- REQUIRED --> <!-- VALIDATION: must reference an existing EPIC-NNN -->
title: "{{ story_title }}"
<!-- REQUIRED --> <!-- VALIDATION: max 100 chars; should summarize the user action -->
status: "{{ status }}"
<!-- REQUIRED --> <!-- VALIDATION: one of Backlog | Ready | In Progress | Review | Done -->
points: {{ story_points }}
<!-- REQUIRED --> <!-- VALIDATION: Fibonacci value (1, 2, 3, 5, 8, 13); prefer <= 8 -->
priority: "{{ priority }}"
<!-- REQUIRED --> <!-- VALIDATION: one of Critical | High | Medium | Low -->
assigned-to: "{{ assignee }}"
<!-- OPTIONAL — can be "unassigned" until sprint planning -->
sprint: "{{ sprint_number }}"
<!-- OPTIONAL — set during sprint planning -->
dependencies:
  - "{{ dependency_story_id }}"
<!-- OPTIONAL — empty array [] if no dependencies -->
acceptance-criteria-count: {{ ac_count }}
<!-- REQUIRED --> <!-- VALIDATION: must match the actual number of AC sections below -->
---

