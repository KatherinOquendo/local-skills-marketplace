graph TD
    subgraph Estrategia["Estrategia de Testing"]
        direction TB
        TestStrategy["Testing Strategy<br/>Arquitectura de calidad"]
        ShiftLeft["Shift-Left Testing<br/>Calidad temprana, costo 10-100x menor"]
        TestPyramid["Test Pyramid<br/>Forma: pyramid, trophy, honeycomb"]
    end

    subgraph Niveles["Niveles de Testing"]
        direction TB
        UnitTest["Unit Tests<br/>Rápidos, aislados, 70% ratio"]
