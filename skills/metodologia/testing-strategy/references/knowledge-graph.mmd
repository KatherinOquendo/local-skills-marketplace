        E2ETest["E2E Tests<br/>Journeys completos, 10% ratio"]
        ContractTest["Contract Tests<br/>Consumer-driven, O(N+M)"]
    end

    subgraph Metodologías["Metodologías"]
        direction TB
        TDD["TDD<br/>Red-Green-Refactor"]
        BDD["BDD<br/>Given-When-Then, Gherkin"]
        PropertyBased["Property-Based Testing<br/>Propiedades universales, shrinking"]
        MutationTest["Mutation Testing<br/>Calidad del test suite >80%"]
    end

    subgraph Automatización["Automatización & CI"]
        direction TB
        TestAutomation["Test Automation<br/>Frameworks, POM, factories"]
        CIIntegration["CI Integration<br/>Gates, triggers, paralelismo"]
        TestImpact["Test Impact Analysis<br/>Cobertura selectiva, 40-70% ahorro"]
        VisualRegression["Visual Regression<br/>Screenshots, diff pixel/perceptual"]
    end

    subgraph Datos["Gestión de Datos"]
        direction TB
        TestDataMgmt["Test Data Management<br/>Factories, aislamiento, compliance"]
        SyntheticData["Datos Sintéticos<br/>Faker, generadores custom"]
        DataAnonymization["Anonimización<br/>PII scrubbing, GDPR"]
        Testcontainers["Testcontainers<br/>DB real en contenedor"]
    end

    subgraph Métricas["Métricas de Calidad"]
        direction TB
        Coverage["Coverage<br/>Line, branch, mutation trends"]
        FlakyTests["Flaky Tests<br/>Quarantine, fix, delete policy"]
        DefectEscape["Defect Escape Rate<br/>Prod vs. pre-prod"]
        QualityGates["Quality Gates<br/>PR merge criteria"]
    end

