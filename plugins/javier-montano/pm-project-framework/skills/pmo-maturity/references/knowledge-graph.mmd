    classDef amber fill:#F59E0B,stroke:#0F172A,color:#0F172A,stroke-width:2px
    classDef dark fill:#0F172A,stroke:#2563EB,color:#FFFFFF,stroke-width:2px

    MAT["PMO Maturity Assessment"]:::blue

    %% Frameworks
    OPM3["OPM3 (PMI)"]:::dark
    P3M3["P3M3 (Axelos)"]:::dark

    %% Dimensions
    PROC["Processes"]:::amber
    PEOPLE["People"]:::amber
    TOOLS["Tools"]:::amber
    GOV["Governance"]:::amber
    CULTURE["Culture"]:::amber

    %% Levels
    L1["Level 1: Awareness"]:::dark
    L2["Level 2: Repeatable"]:::amber
    L3["Level 3: Defined"]:::amber
    L4["Level 4: Managed"]:::blue
    L5["Level 5: Optimized"]:::blue

    %% Outputs
    RADAR["Maturity Radar Chart"]:::blue
    GAP["Gap Analysis"]:::blue
