    classDef primary fill:#2563EB,stroke:#0F172A,color:#FFFFFF
    classDef output fill:#F59E0B,stroke:#0F172A,color:#000000
    classDef dark fill:#0F172A,stroke:#2563EB,color:#FFFFFF

    class B primary
    class G,H,I dark
    class J,K,L,M output
