%% Knowledge Graph — Risk Register & Identification
%% Shows skill dependencies, data flows, and agent relationships

graph TB
    subgraph Inputs
        CHARTER[project-charter<br/>Phase 0]
        WBS[scope-wbs<br/>Phase 2]
        SCHED[schedule-baseline<br/>Phase 3]
        ASSUME[assumption-log<br/>Phase 0]
        STAKE[stakeholder-register<br/>Phase 1]
    end

    subgraph "Risk Register (This Skill)"
        IDENT[Risk Identification<br/>8 techniques]
        CATEG[RBS Categorization<br/>4 L1 categories]
        ASSESS[P×I Assessment<br/>5-point scale]
        REGISTER[Risk Register<br/>Formal document]
    end

    subgraph Downstream
        QUANT[risk-quantification<br/>Monte Carlo, EMV]
        RESPONSE[risk-response-planning<br/>Strategies]
        MONITOR[risk-monitoring<br/>Continuous tracking]
        CONTINGENCY[contingency-planning<br/>Reserve allocation]
        STEERING[steering-review<br/>Go/No-Go G1.5]
    end

    subgraph Agents
        RISK_ANALYST[risk-analyst<br/>L3 Specialist]
        RISK_MGR[risk-manager<br/>L1 Triad]
        CONDUCTOR[project-conductor<br/>L1 Triad]
    end

    CHARTER --> IDENT
    WBS --> IDENT
    SCHED --> IDENT
    ASSUME --> IDENT
    STAKE --> IDENT

    IDENT --> CATEG --> ASSESS --> REGISTER

    REGISTER --> QUANT
    REGISTER --> RESPONSE
    REGISTER --> MONITOR
    REGISTER --> CONTINGENCY
    REGISTER --> STEERING

    RISK_ANALYST -.->|executes| IDENT
    RISK_MGR -.->|validates| REGISTER
    CONDUCTOR -.->|orchestrates| REGISTER

    style REGISTER fill:#2563EB,color:#fff,stroke:#1d4ed8
    style RISK_MGR fill:#F59E0B,color:#0F172A,stroke:#d97706
    style CONDUCTOR fill:#F59E0B,color:#0F172A,stroke:#d97706
