    MONGODB["MongoDB / Document"]
    CASSANDRA["Cassandra / Wide-Column"]
    REDIS["Redis / Cache"]
    DYNAMODB["DynamoDB"]
  end

  %% === SPECIALIZED ===
  subgraph SPECIALIZED["Specialized Engines"]
