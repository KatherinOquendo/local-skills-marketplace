  class WORKLOAD,ACCESS,VOLUME sofkaPrimary
  class POSTGRES,MYSQL,NEWSQL,ALLOYDB,MONGODB,CASSANDRA,REDIS,DYNAMODB sofkaDark
  class GRAPH_DB,TIMESERIES,VECTOR_DB,SEARCH sofkaDark
  class NORMALIZATION,DENORM,CONSTRAINTS,NAMING,TEMPORAL sofkaLight
  class BTREE,GIN,BRIN,COVERING,PARTIAL,MVCC sofkaSuccess
  class RANGE_PART,HASH_PART,SHARDING,REPLICATION,CONSENSUS,FAILOVER sofkaPrimary
  class ER_DIAGRAM,MIGRATION_PLAN,PERF_REPORT,MONITORING sofkaSuccess
