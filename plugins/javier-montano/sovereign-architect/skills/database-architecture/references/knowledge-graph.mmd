  %% === Conexiones ===
  WORKLOAD --> POSTGRES
  WORKLOAD --> MONGODB
  WORKLOAD --> GRAPH_DB
  ACCESS --> BTREE
  ACCESS --> GIN
  VOLUME --> RANGE_PART
  VOLUME --> SHARDING

  POSTGRES --> NORMALIZATION
  MYSQL --> NORMALIZATION
  NEWSQL --> SHARDING
  ALLOYDB --> REPLICATION
  MONGODB --> DENORM
  CASSANDRA --> HASH_PART
  REDIS --> COVERING
  DYNAMODB --> HASH_PART

  GRAPH_DB --> CONSTRAINTS
  TIMESERIES --> BRIN
  VECTOR_DB --> PARTIAL
  SEARCH --> GIN

  NORMALIZATION --> BTREE
  DENORM --> COVERING
  CONSTRAINTS --> NAMING
  TEMPORAL --> RANGE_PART

  BTREE --> MVCC
  BRIN --> RANGE_PART
  PARTIAL --> MVCC
  MVCC --> REPLICATION

  RANGE_PART --> FAILOVER
  SHARDING --> CONSENSUS
  REPLICATION --> FAILOVER

  NORMALIZATION --> ER_DIAGRAM
  FAILOVER --> MONITORING
  CONSENSUS --> MIGRATION_PLAN
  MVCC --> PERF_REPORT

  DATA_ARCH --> DESIGN
  BACKEND_DEV --> OPTIMIZATION
  DBA --> DISTRIBUTION

  %% === Estilos Sofka ===
  classDef sofkaPrimary fill:#FF7E08,stroke:#1A1A2E,color:#1A1A2E,stroke-width:2px
