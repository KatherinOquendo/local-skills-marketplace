    VOLUME["Data Volume & Growth"]
  end

  %% === RELATIONAL ===
  subgraph RELATIONAL["Relational & SQL"]
    direction TB
    POSTGRES["PostgreSQL"]
    MYSQL["MySQL"]
    NEWSQL["NewSQL / CockroachDB"]
    ALLOYDB["AlloyDB / TiDB"]
  end

  %% === NOSQL ===
  subgraph NOSQL["NoSQL"]
