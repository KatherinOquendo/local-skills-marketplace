graph LR

    %% ── INPUTS ──────────────────────────────────────────
    subgraph INPUTS["📥 INPUTS"]
        rawText["Texto crudo<br/>del usuario"]
        convContext["Contexto de<br/>conversación"]
        attachments["Adjuntos<br/>mencionados"]
        emotionalSignals["Señales<br/>emocionales"]
    end

    %% ── PASSES ──────────────────────────────────────────
    subgraph PASSES["🔬 CINCO PASES"]
        pass1["Pase 1<br/>Superficie"]
        pass2["Pase 2<br/>5 Porqués"]
        pass3["Pase 3<br/>7 Entonces-qués"]
        pass4["Pase 4<br/>Intención"]
        pass5["Pase 5<br/>Reformulación"]
    end

    %% ── PATTERNS ────────────────────────────────────────
    subgraph PATTERNS["🔍 PATRONES DE DETECCIÓN"]
        dyslexia["Dislexia<br/>inversiones b/d, p/q"]
        haste["Afán<br/>abreviaciones extremas"]
        orthography["Ortografía<br/>fonética, tildes"]
        punctuation["Puntuación<br/>ausencia, exceso"]
        syntax["Sintaxis<br/>fragmentos, run-on"]
        autocorrect["Autocorrect<br/>sustituciones"]
        spanglish["Spanglish<br/>mezcla es-en"]
    end

    %% ── OUTPUTS ─────────────────────────────────────────
    subgraph OUTPUTS["📤 OUTPUTS"]
        correctedText["Texto<br/>corregido"]
